# ═══════════════════════════════════════════════════════════════
# Konten Niche Pro — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to Git!

# Database
DATABASE_URL=sqlite:///data.db

# Cookie file for yt-dlp (export from browser using a cookie extension)
COOKIES_FILE=cookies.txt

# Directory to store downloaded videos
DOWNLOAD_DIR=downloads

# Logging
LOG_FILE=app.log
LOG_LEVEL=INFO

# ── AI Caption Generation (at least one required for AI captions) ──
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Ngrok (required for Instagram upload via public URL) ──
NGROK_AUTHTOKEN=

# ── Composio (required for Instagram & TikTok upload automation) ──
COMPOSIO_API_KEY=

# ── Google OAuth (required for YouTube upload) ──
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json
